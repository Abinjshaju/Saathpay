# ============================================================
# SaathPay — Environment Variables
# Copy to .env and fill in values.
# ============================================================

# --- Docker Compose Ports ---
USER_UI_PORT=8082
ADMIN_UI_PORT=8081
BACKEND_PORT=8000

# --- Vite (baked at build time) ---
VITE_API_BASE_URL=/api/v1

# --- Supabase ---
SUPABASE_URL=https://wglrploxsxevcewrfsmb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Used only at migration time (psql / Supabase SQL editor); not read by the app at runtime.
DATABASE_URL=postgresql://postgres:PASSWORD@db.wglrploxsxevcewrfsmb.supabase.co:5432/postgres

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# --- Twilio (initial defaults; runtime values come from the `settings` row) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_SENDER=whatsapp:+14155238886
TWILIO_SMS_SENDER=

# --- CORS ---
# Comma-separated list of admin frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:8080,http://localhost:8081,http://localhost:8082

# --- Storage ---
SUPABASE_LOGO_BUCKET=org-logos
LOGO_SIGNED_URL_TTL_SECONDS=3600
LOGO_MAX_BYTES=2097152

# --- App ---
APP_NAME=Saathpay Admin API
APP_ENV=development